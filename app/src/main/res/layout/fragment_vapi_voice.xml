<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="600dp">

        <!-- Top branding gradient area -->
        <View
            android:id="@+id/topGradient"
            android:layout_width="0dp"
            android:layout_height="240dp"
            android:background="@drawable/vapi_gradient_bg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Pulse rings (visible during active call) -->
        <ImageView
            android:id="@+id/pulseRingOuter"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:src="@drawable/vapi_pulse_ring_outer"
            android:visibility="gone"
            android:alpha="0.4"
            app:layout_constraintBottom_toBottomOf="@id/avatarCircle"
            app:layout_constraintEnd_toEndOf="@id/avatarCircle"
            app:layout_constraintStart_toStartOf="@id/avatarCircle"
            app:layout_constraintTop_toTopOf="@id/avatarCircle" />

        <ImageView
            android:id="@+id/pulseRingInner"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/vapi_pulse_ring"
            android:visibility="gone"
            android:alpha="0.6"
            app:layout_constraintBottom_toBottomOf="@id/avatarCircle"
            app:layout_constraintEnd_toEndOf="@id/avatarCircle"
            app:layout_constraintStart_toStartOf="@id/avatarCircle"
            app:layout_constraintTop_toTopOf="@id/avatarCircle" />

        <!-- Avatar Circle -->
        <LinearLayout
            android:id="@+id/avatarCircle"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginTop="48dp"
            android:background="@drawable/vapi_avatar_glow"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/avatarIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎤"
                android:textSize="40sp" />
        </LinearLayout>

        <!-- Assistant Name -->
        <TextView
            android:id="@+id/assistantName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="NMA IT Voice"
            android:textColor="#F8FAFC"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/avatarCircle" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Automation Sales Assistant"
            android:textColor="#64748B"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/assistantName" />

        <!-- Status Indicator -->
        <LinearLayout
            android:id="@+id/statusIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:background="@drawable/vapi_status_bg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/assistantName">

            <View
                android:id="@+id/statusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/vapi_dot_idle"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to start"
                android:textColor="#94A3B8"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Main Action Button -->
        <LinearLayout
            android:id="@+id/startStopButton"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="36dp"
            android:background="@drawable/vapi_main_btn"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/statusIndicator">

            <TextView
                android:id="@+id/startStopIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎤"
                android:textSize="34sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tap to start speaking"
            android:textColor="#475569"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/startStopButton" />

        <!-- Transcript Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/transcriptCard"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="32dp"
            android:visibility="gone"
            app:cardBackgroundColor="#1E293B"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/startStopButton">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="20dp">

                <TextView
                    android:id="@+id/transcriptText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:lineSpacingExtra="6sp"
                    android:text="Speak now..."
                    android:textColor="#E2E8F0"
                    android:textSize="15sp" />
            </ScrollView>
        </androidx.cardview.widget.CardView>

        <!-- Volume slider row (visible during active call) -->
        <LinearLayout
            android:id="@+id/volumeRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="48dp"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingVertical="8dp"
            android:paddingHorizontal="12dp"
            android:background="@drawable/vapi_volume_bg"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/transcriptCard">

            <ImageView
                android:id="@+id/volumeIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_volume"
                android:tint="#94A3B8"
                android:layout_marginEnd="12dp" />

            <SeekBar
                android:id="@+id/volumeSlider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="90"
                android:thumbTint="#2563EB"
                android:progressTint="#2563EB"
                android:progressBackgroundTint="#334155" />

            <TextView
                android:id="@+id/volumePercent"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:text="90%"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:gravity="end"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Control buttons row -->
        <LinearLayout
            android:id="@+id/controlRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingBottom="40dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/volumeRow">

            <!-- Speaker -->
            <LinearLayout
                android:id="@+id/speakerButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/vapi_control_btn"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/speakerIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_speaker"
                    android:tint="#22C55E" />
            </LinearLayout>

            <!-- Mute -->
            <LinearLayout
                android:id="@+id/muteButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/vapi_control_btn"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/micIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_mic"
                    android:tint="#94A3B8" />
            </LinearLayout>

            <!-- Hang up -->
            <LinearLayout
                android:id="@+id/hangupButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/vapi_hangup_btn"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_call_end"
                    android:tint="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
