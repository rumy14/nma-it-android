<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="SERVICES"
            android:textColor="#2563EB"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Three Tiers. One Goal: Save You Time."
            android:textColor="#F8FAFC"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Tier 1: Starter -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="#1E293B"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:text="STARTUP"
                    android:textColor="#2563EB"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="Starter Automations"
                    android:textColor="#F8FAFC"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="$500–$2,000"
                    android:textColor="#F8FAFC"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="Perfect for businesses taking their first step into automation."
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="3sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#334155" android:layout_marginVertical="14dp" />

                <TextView android:text="🤖 Custom GPT / AI Assistant" android:textColor="#CBD5E1" android:textSize="14sp" android:paddingVertical="4dp" android:layout_width="match_parent" android:layout_height="wrap_content" />
                <TextView android:text="🔗 Zapier / Make Automation" android:textColor="#CBD5E1" android:textSize="14sp" android:paddingVertical="4dp" android:layout_width="match_parent" android:layout_height="wrap_content" />
                <TextView android:text="📧 Email Sequences" android:textColor="#CBD5E1" android:textSize="14sp" android:paddingVertical="4dp" android:layout_width="match_parent" android:layout_height="wrap_content" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tier 2: Growth -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#1E293B"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:text="GROWTH"
                    android:textColor="#2563EB"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="Growth Automations"
                    android:textColor="#F8FAFC"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="$2,000–$5,000"
                    android:textColor="#F8FAFC"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="For businesses ready to scale with smarter workflows."
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="3sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#334155" android:layout_marginVertical="14dp" />

                <TextView android:text="🔄 Multi-Step Workflow" android:textColor="#CBD5E1" android:textSize="14sp" android:paddingVertical="4dp" android:layout_width="match_parent" android:layout_height="wrap_content" />
                <TextView android:text="📊 Custom Dashboards" android:textColor="#CBD5E1" android:textSize="14sp" android:paddingVertical="4dp" android:layout_width="match_parent" android:layout_height="wrap_content" />
                <TextView android:text="🤝 CRM Integration" android:textColor="#CBD5E1" android:textSize="14sp" android:paddingVertical="4dp" android:layout_width="match_parent" android:layout_height="wrap_content" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tier 3: Enterprise -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#1E293B"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:text="ENTERPRISE"
                    android:textColor="#2563EB"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="Custom Solutions"
                    android:textColor="#F8FAFC"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="$5,000+"
                    android:textColor="#F8FAFC"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="Tailor-made automation for complex business needs."
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="3sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#334155" android:layout_marginVertical="14dp" />

                <TextView android:text="🔌 API Integration Platform" android:textColor="#CBD5E1" android:textSize="14sp" android:paddingVertical="4dp" android:layout_width="match_parent" android:layout_height="wrap_content" />
                <TextView android:text="🧠 Custom AI Agent" android:textColor="#CBD5E1" android:textSize="14sp" android:paddingVertical="4dp" android:layout_width="match_parent" android:layout_height="wrap_content" />
                <TextView android:text="🏗️ Full-Stack Automation" android:textColor="#CBD5E1" android:textSize="14sp" android:paddingVertical="4dp" android:layout_width="match_parent" android:layout_height="wrap_content" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Spacer -->
        <View android:layout_width="match_parent" android:layout_height="20dp" />

    </LinearLayout>
</ScrollView>
