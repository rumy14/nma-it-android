<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_bg"
    android:minHeight="400dp">

    <!-- Handle -->
    <View
        android:id="@+id/handle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bottom_sheet_handle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Header -->
    <ImageView
        android:id="@+id/chatAvatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:src="@drawable/ic_chat_avatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/handle" />

    <TextView
        android:id="@+id/chatTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="48dp"
        android:text="NMA IT Assistant"
        android:textColor="#F8FAFC"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/chatAvatar"
        app:layout_constraintEnd_toStartOf="@id/voiceToggle"
        app:layout_constraintStart_toEndOf="@id/chatAvatar"
        app:layout_constraintTop_toTopOf="@id/chatAvatar" />

    <TextView
        android:id="@+id/chatSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="AI Automation Sales Bot"
        android:textColor="#94A3B8"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="@id/chatTitle"
        app:layout_constraintStart_toStartOf="@id/chatTitle"
        app:layout_constraintTop_toBottomOf="@id/chatTitle" />

    <ImageButton
        android:id="@+id/voiceToggle"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:background="?selectableItemBackgroundBorderless"
        android:src="@drawable/ic_voice_on"
        android:contentDescription="Toggle voice mode"
        android:tint="#94A3B8"
        app:layout_constraintBottom_toBottomOf="@id/chatAvatar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/chatAvatar" />

    <View
        android:id="@+id/headerDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="#1E293B"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chatAvatar" />

    <!-- Messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:padding="12dp"
        android:paddingBottom="4dp"
        app:layout_constraintBottom_toTopOf="@id/inputDivider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerDivider" />

    <View
        android:id="@+id/inputDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#1E293B"
        app:layout_constraintBottom_toTopOf="@id/inputLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Input area -->
    <LinearLayout
        android:id="@+id/inputLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/micButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="Voice input"
            android:src="@drawable/ic_mic"
            android:tint="#64748B" />

        <EditText
            android:id="@+id/chatInput"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/chat_input_bg"
            android:gravity="center_vertical"
            android:hint="Type a message..."
            android:imeOptions="actionSend"
            android:inputType="text"
            android:maxLines="3"
            android:paddingHorizontal="14dp"
            android:singleLine="true"
            android:textColor="#F8FAFC"
            android:textColorHint="#64748B"
            android:textSize="14sp" />

        <ImageButton
            android:id="@+id/sendButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="Send message"
            android:src="@drawable/ic_send"
            android:tint="#2563EB" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
