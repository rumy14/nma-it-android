<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NMAIT" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">#0F172A</item>
        <item name="android:navigationBarColor">#0F172A</item>
        <item name="android:windowBackground">#0F172A</item>
        <item name="colorPrimary">#2563EB</item>
        <item name="colorPrimaryDark">#0F172A</item>
        <item name="colorAccent">#2563EB</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.NMAIT.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0F172A</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.NMAIT</item>
    </style>

    <!-- Bottom sheet theme -->
    <style name="Theme.NMAIT.BottomSheet" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">#0F172A</item>
        <item name="bottomSheetStyle">@style/Widget.NMAIT.BottomSheet</item>
    </style>

    <style name="Widget.NMAIT.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <!-- Text input style -->
    <style name="Widget.NMAIT.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">#1E293B</item>
        <item name="boxStrokeColor">#334155</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">#64748B</item>
        <item name="android:textColorHint">#64748B</item>
    </style>
</resources>
